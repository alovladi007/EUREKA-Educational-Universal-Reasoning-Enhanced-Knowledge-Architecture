# AXIOM environment sample. Copy to .env for local runs outside Docker.

# Backend (prefix AXIOM_)
AXIOM_ENV=development
AXIOM_DATABASE_URL=postgresql+asyncpg://axiom:axiom@localhost:5440/axiom
AXIOM_REDIS_URL=redis://localhost:6390/0
AXIOM_IDENTITY_PROVIDER=mock
AXIOM_EUREKA_JWT_SECRET=eureka_dev_secret_key_change_in_production
AXIOM_EUREKA_JWT_ALGORITHM=HS256

# Frontend (Next.js)
NEXT_PUBLIC_AXIOM_API_URL=http://localhost:8400
NEXT_PUBLIC_EUREKA_LOGIN_URL=http://localhost:4040/auth/login
