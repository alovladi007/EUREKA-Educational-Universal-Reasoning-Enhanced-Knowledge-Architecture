# AXIOM web app environment variables.
# Copy this file to .env.local and adjust as needed.

# Base URL of the AXIOM API. The web app sends the EUREKA JWT as a
# Bearer token to this host.
NEXT_PUBLIC_AXIOM_API_URL=http://localhost:8400

# Where to send users who are not signed in. This is EUREKA's login page.
NEXT_PUBLIC_EUREKA_LOGIN_URL=http://localhost:4040/auth/login
