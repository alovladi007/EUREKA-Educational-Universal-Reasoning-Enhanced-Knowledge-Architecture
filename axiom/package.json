{
  "name": "axiom",
  "private": true,
  "version": "0.1.0",
  "description": "AXIOM - Adaptive eXpert Instruction and Outcome Measurement. The mathematics vertical of EUREKA.",
  "workspaces": [
    "apps/web",
    "packages/ui"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
