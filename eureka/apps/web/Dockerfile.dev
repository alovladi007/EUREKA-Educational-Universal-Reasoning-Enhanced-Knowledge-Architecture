FROM node:20-alpine

WORKDIR /app

# Install dependencies. .npmrc carries legacy-peer-deps=true so the
# vitest@4 → vite@8 → @vitejs/plugin-react@6 peer chain resolves
# against @types/node@20 (added with the P3-13 test scaffolding).
# Without it `npm install` dies on ERESOLVE in the Docker build.
COPY package*.json .npmrc ./
RUN npm install

# Copy source code
COPY . .

# Expose port
EXPOSE 3000

# Start the dev server with a self-warming sidecar (XR-9):
# 1. Clear .next first — it lives in an anonymous volume that SURVIVES
#    `--force-recreate`, so after an image rebuild the new server booted
#    against the previous image's webpack cache. Next 14 dev dies silently
#    (clean exit, no error) on a mismatched cache; observed as 2 restarts in
#    the first ~2 minutes after every rebuild, then stability once the cache
#    had been rewritten. A clean cache makes boots deterministic.
# 2. warm-routes.mjs waits for the server then pre-compiles the heavy routes,
#    so a restart/rebuild never leaves the user's first clicks paying
#    multi-second on-demand compiles (it also absorbs the cache-clear cost).
# `exec` keeps npm receiving container signals directly.
CMD ["sh", "-c", "rm -rf /app/.next/* 2>/dev/null; node scripts/warm-routes.mjs & exec npm run dev"]
