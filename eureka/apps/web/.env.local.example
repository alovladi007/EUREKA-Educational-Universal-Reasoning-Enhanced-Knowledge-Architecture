# API Configuration
# api-core runs in Docker on host port 8000 (see docker-compose.yml,
# the `api-core` service's `ports: - "8000:8000"`). The api-client
# default in src/lib/api-client.ts is 8009, which is what you'd get
# without an .env.local — but 8009 isn't bound anywhere. Copy this
# file to `.env.local` to wire the front-end to the real api-core.
NEXT_PUBLIC_API_URL=http://localhost:8000
# test-prep microservice (Patent Bar bookmarks, MPEP analytics, etc.)
# behind the `--profile full` compose flag on port 8200.
NEXT_PUBLIC_TEST_PREP_URL=http://localhost:8200
NEXT_PUBLIC_TUTOR_URL=http://localhost:8101

# Authentication
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:4040

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_TUTOR=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_COLLABORATION=true
