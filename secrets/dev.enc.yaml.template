# Template for the dev secrets file.
#
# Copy this to secrets/dev.enc.yaml, fill in real values, then encrypt:
#   sops -e -i secrets/dev.enc.yaml
#
# After encryption the file's *keys* stay in plaintext (so you can see
# what's set without decrypting) but *values* are ciphertext. Safe to
# commit.
#
# Secrets in scope: every external credential the dev stack needs to
# function. Local-only secrets (db password = "eureka_dev_password",
# minio key, etc.) don't need SOPS — they're checked into docker-compose
# as-is because they only protect the dev container against itself.
#
# Do NOT add real secrets here in plaintext and commit. If you accidentally
# do, treat it as a leak: rotate the credential, then git filter-branch.

# Anthropic Claude — required for AI tutor, AI grading, content authoring.
ANTHROPIC_API_KEY: "REPLACE_ME_then_sops_encrypt"

# OpenAI — fallback for AI tutor / embeddings.
OPENAI_API_KEY: "REPLACE_ME_then_sops_encrypt"

# JWT signing — must persist across api-core restarts in any env >= dev.
# Generate with: openssl rand -hex 32
JWT_SECRET: "REPLACE_ME_then_sops_encrypt"

# MFA Fernet envelope — every TOTP secret in the users table is encrypted
# under this. LOSING THIS = every user's MFA enrolment becomes unreadable.
# Generate with:
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
MFA_ENVELOPE_KEY: "REPLACE_ME_then_sops_encrypt"

# Stripe (test mode for dev).
STRIPE_SECRET_KEY: "REPLACE_ME_then_sops_encrypt"
STRIPE_WEBHOOK_SECRET: "REPLACE_ME_then_sops_encrypt"

# SMTP (for transactional email — Resend, Postmark, SendGrid, etc.).
SMTP_PASSWORD: "REPLACE_ME_then_sops_encrypt"

# Sentry DSN — error reporting. Public-ish but treat as semi-secret.
SENTRY_DSN: "REPLACE_ME_then_sops_encrypt"
