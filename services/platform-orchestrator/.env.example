# Platform Orchestrator Configuration

# Server
PORT=3000
NODE_ENV=development
API_VERSION=v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eureka
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Service Discovery - Microservice URLs
# Core Services
AUTH_SERVICE_URL=http://localhost:3001
TEST_PREP_SERVICE_URL=http://localhost:3002
AI_TUTOR_SERVICE_URL=http://localhost:3003
XR_LABS_SERVICE_URL=http://localhost:3005
NOTEBOOK_SERVICE_URL=http://localhost:3006

# Educational Tier Services
HIGH_SCHOOL_SERVICE_URL=http://localhost:8010
UNDERGRADUATE_SERVICE_URL=http://localhost:8011
GRADUATE_SERVICE_URL=http://localhost:8012

# Professional Services
MEDICAL_SCHOOL_SERVICE_URL=http://localhost:8020
LAW_SCHOOL_SERVICE_URL=http://localhost:8021
MBA_SERVICE_URL=http://localhost:8022
ENGINEERING_SERVICE_URL=http://localhost:8023

# Platform Services
DATA_FABRIC_SERVICE_URL=http://localhost:3010
MARKETPLACE_SERVICE_URL=http://localhost:3011
ANALYTICS_SERVICE_URL=http://localhost:3012

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30000
SERVICE_TIMEOUT=5000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Cache
CACHE_TTL=300
CACHE_MAX_KEYS=1000
