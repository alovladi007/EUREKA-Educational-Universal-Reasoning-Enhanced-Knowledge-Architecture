{
  "name": "@eureka/platform-orchestrator",
  "version": "1.0.0",
  "description": "EUREKA Platform Orchestrator - Unified API Gateway and Service Coordinator",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "eureka",
    "api-gateway",
    "orchestrator",
    "microservices",
    "education"
  ],
  "author": "EUREKA Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "express-rate-limit": "^7.1.5",
    "winston": "^3.11.0",
    "axios": "^1.6.2",
    "http-proxy-middleware": "^2.0.6",
    "redis": "^4.6.11",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "socket.io": "^4.6.0",
    "socket.io-client": "^4.6.0",
    "swagger-ui-express": "^5.0.0",
    "express-validator": "^7.0.1",
    "node-cache": "^5.1.2",
    "uuid": "^9.0.1"
