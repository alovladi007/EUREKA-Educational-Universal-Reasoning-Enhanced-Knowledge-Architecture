# Server Configuration
PORT=3005
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eureka
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# AWS S3 Configuration (for 3D asset storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=eureka-xr-assets

# CDN Configuration
CDN_BASE_URL=https://cdn.eureka-xr.com

# WebXR Configuration
WEBXR_ENABLED=true
MAX_CONCURRENT_VR_SESSIONS=100

# Collaborative VR Settings
MAX_ROOM_PARTICIPANTS=10
VOICE_CHAT_ENABLED=true

# 3D Asset Processing
MAX_ASSET_SIZE_MB=100
SUPPORTED_FORMATS=glb,gltf,fbx,obj,usdz
AUTO_OPTIMIZE_ASSETS=true

# Performance Settings
TARGET_FPS=90
MAX_POLYGON_COUNT=1000000

# Monitoring
ENABLE_ANALYTICS=true
LOG_LEVEL=info
