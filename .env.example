# EUREKA environment template — copy to .env and fill in real values.
# .env is gitignored; NEVER commit real secrets. These are placeholders only.

# ── Database / cache ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://eureka:CHANGE_ME@localhost:5434/eureka
DATABASE_TEST_URL=postgresql://eureka:CHANGE_ME@localhost:5434/eureka_test
REDIS_URL=redis://localhost:6381/0

# ── Auth ────────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_generate_a_long_random_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI providers (optional — features degrade gracefully without keys) ───────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_MAX_TOKENS=2000
RAG_ENABLED=true
AI_FALLBACK_ENABLED=true

# ── Uploads / object storage ────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=pdf,png,jpg,jpeg,docx
# MinIO (S3-compatible) — see docker-compose minio service
S3_ENDPOINT=localhost:9004
S3_ACCESS_KEY=eureka
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET_NAME=eureka-files
S3_SECURE=false

# ── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_FROM_NAME=EUREKA

# ── Frontend (Next.js public vars) ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_APP_NAME=EUREKA
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── Service ports (host-published) ──────────────────────────────────────────
API_CORE_PORT=8000
FILE_STORAGE_PORT=8300

# ── Observability / limits ──────────────────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=
PROMETHEUS_ENABLED=false
GRAFANA_ENABLED=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
